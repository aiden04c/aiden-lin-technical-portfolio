      <div class="section-header">
        <span class="section-tag">Expertise</span>
        <h2 class="section-title">Technical Skills</h2>
      </div>
      <div class="skills-grid">
        {[
          { icon: '🚀', title: 'Cloudflare Content Delivery & DNS Managment', items: ['Workers', 'Pages', 'DNS', 'Load Balancing', 'R2', 'KV', ] },
          { icon: '📝', title: 'Project Management & Planning', items: ['Microsoft Project', '...', '...', '...'] },
