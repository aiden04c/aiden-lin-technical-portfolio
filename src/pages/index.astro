                <polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <div class="project-tags"><span class="tag">Hugo</span><span class="tag">Docker</span><span class="tag">K8s</span></div>
          </div>
          <h3 class="project-title">Product Handbook</h3>
          <p class="project-description">Internal documentation platform built with Hugo, containerized with Docker, and deployed to Kubernetes. Features GitLab CI/CD pipeline and automated deployments.</p>
          <div class="project-features">
            <div class="feature"><span class="feature-label">Stack</span><span class="feature-value">Hugo + Docker + K8s</span></div>
          </div>
        </article>
