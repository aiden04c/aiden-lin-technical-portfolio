---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Aiden Lin — Client Delivery & Cloud-Enabled Solutions"
  description="Aiden Lin (Lin Shi Cheng) — client-facing project lead with hands-on Cloudflare delivery experience. MSc candidate at NUS, advisor at HKePark, and former consulting/property/engineering intern at Knight Frank, CBRE Asia Pacific, and PNH Group. Pursuing Solutions Engineer and Account Manager roles across APAC."
>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-grid"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="hero-badge">
      <span class="badge-dot"></span>
      Open to Solutions Engineer & Account Manager roles · APAC
    </div>
    <div class="hero-content">
      <h1 class="hero-title">
        <span class="title-line">Hi, I'm Aiden Lin —</span>
        <span class="title-gradient">I run client delivery and ship the platform behind&nbsp;it.</span>
      </h1>
      <p class="hero-description">
        MSc from the National University of Singapore and BEng from Loughborough University. I run multi-stakeholder delivery, ship Cloudflare platforms end-to-end, and help brands reach new markets — building the pitch site that takes HKePark to the Hong Kong government, and designing the growth strategy that moves Chen Tian from WeChat and Douyin to Google Ads and international buyers. I turn technical detail and commercial data into outcomes that clients and senior stakeholders can act on.
      </p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">
          <span>See Projects</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#contact" class="btn btn-secondary">Get in Touch</a>
      </div>
    </div>
    <div class="hero-right">
    <div class="hero-visual">
      <!-- Project Snapshot Card (replaces dev terminal) -->
      <div class="snapshot-card">
        <div class="snapshot-header">
          <div class="snapshot-tag">
            <span class="snapshot-dot"></span>
            <span>Live deployments</span>
          </div>
          <span class="snapshot-host">edge · global</span>
        </div>
        <div class="snapshot-body">
          <div class="arch-diagram">
            <div class="arch-node">
              <div class="arch-icon">🌏</div>
              <span class="arch-label">Visitors</span>
              <small>HK · SG · CN · Global</small>
            </div>
            <div class="arch-arrow">
              <svg viewBox="0 0 40 12" fill="none" aria-hidden="true">
                <path d="M2 6h32m0 0l-5-4m5 4l-5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="arch-node arch-node--center">
              <div class="arch-icon">⚡</div>
              <span class="arch-label">Cloudflare Edge</span>
              <small>Workers · Pages · DNS</small>
            </div>
            <div class="arch-arrow">
              <svg viewBox="0 0 40 12" fill="none" aria-hidden="true">
                <path d="M2 6h32m0 0l-5-4m5 4l-5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="arch-node">
              <div class="arch-icon">📦</div>
              <span class="arch-label">Storage</span>
              <small>KV · R2</small>
            </div>
          </div>
          <div class="snapshot-products">
            <div class="product-row">
              <div class="product-meta-stack">
                <a href="https://hkepark.com" target="_blank" rel="noopener" class="product-name product-link">hkepark.com</a>
                <span class="product-meta">Smart curb billing · NUS × HKUST · pitching HKSAR Transport</span>
              </div>
              <span class="product-status">live</span>
            </div>
            <div class="product-row">
              <div class="product-meta-stack">
                <a href="https://chentian.aiden04c.workers.dev" target="_blank" rel="noopener" class="product-name product-link">chentian.aiden04c.workers.dev</a>
                <span class="product-meta">Auto-parts brand · domestic→overseas marketing site</span>
              </div>
              <span class="product-status">live</span>
            </div>
          </div>
          <div class="snapshot-footer">
            <span class="snapshot-pill">Bilingual EN / 中</span>
            <span class="snapshot-pill">Edge-cached globally</span>
            <span class="snapshot-pill">Custom DNS</span>
            <span class="snapshot-pill">End-to-end owned</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero-badges">
      <span class="cloud-badge">☁️ Cloudflare Workers · Pages · KV · R2 · DNS</span>
      <span class="cloud-badge">📊 Google Ads Measurement Certified®</span>
      <span class="cloud-badge">📈 Multi-channel Growth · SEA Expansion</span>
    </div>
    </div>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">S$9M+</span>
        <span class="stat-label">Client portfolio value pitched, won &amp; delivered</span>
      </div>
      <div class="stat">
        <span class="stat-value">5 Deals</span>
        <span class="stat-label">Won through proposals, pricing &amp; solution advisory</span>
      </div>
      <div class="stat">
        <span class="stat-value">13–15%</span>
        <span class="stat-label">Cost cut via strategic value engineering &amp; negotiation</span>
      </div>
      <div class="stat">
        <span class="stat-value">2 Platforms</span>
        <span class="stat-label">Live on Cloudflare — scoped, built &amp; owned end-to-end</span>
      </div>
    </div>
    <div class="hero-strengths">
      <span class="strength-chip">Strategic Account Planning</span>
      <span class="strength-chip">Proposal &amp; Deal Structuring</span>
      <span class="strength-chip">Multi-stakeholder Delivery</span>
      <span class="strength-chip">Project Management</span>
      <span class="strength-chip">Digital Growth &amp; Market Expansion</span>
      <span class="strength-chip">Cloudflare Platform Delivery</span>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">About Me</span>
        <h2 class="section-title">From brief to signature — across engineering rooms and boardrooms</h2>
      </div>
      <div class="about-content">
        <div class="about-text">
          <p>
            I run client-facing engagements across Singapore, Hong Kong and the UK — translating complex briefs into structured plans and delivering measurable outcomes. At Knight Frank I lead workplace consulting and fit-out projects; at HKePark I co-built the commercial case and shipped the bilingual Cloudflare platform the team pitches to the HKSAR Transport Department; for Chen Tian I scoped and delivered their first international storefront, enabling cross-border sales to APAC buyers for the first time.
          </p>
          <div class="card-expand">
            <div class="card-expand-body">
              <p>
                I'm a data-driven communicator: I synthesise messy datasets — site usage, work-order volume, vendor quotes, conversion data — into recommendations that have informed pricing, procurement and growth decisions for senior stakeholders. I'm Google Ads Measurement Certified®, so I'm also fluent in conversion tracking, GA4↔Google Ads attribution, incrementality, MMM and audience-signal conversations.
              </p>
              <p>
                I build on Cloudflare's developer platform — Workers, Pages, KV, R2, DNS and Load Balancing — and have two live products to show for it. For clients that means I can scope a solution, own the delivery, and keep the commercial narrative tight at every stage. I can stand next to an engineer at a whiteboard <em>and</em> next to a buyer in a boardroom, and keep both moving toward signature.
              </p>
            </div>
            <button class="card-expand-toggle" aria-expanded="false">
              <span class="expand-label">Read more</span>
              <svg class="expand-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <div class="about-highlights">
            {[
              { icon: '🤝', title: 'Multi-stakeholder translation', desc: 'Three years of running rooms full of clients, consultants, contractors, government partners and academic teams. RAID logs, status reports, change-order packs, senior-stakeholder updates — I keep narratives consistent across audiences and turn ambiguity into a decision-ready brief.' },
              { icon: '📊', title: 'Numbers into a story', desc: 'I work end-to-end with operational and commercial data: site discovery, KPI/work-order dashboards, vendor cost models, conversion telemetry. I focus on the one chart that moves a stakeholder from "interesting" to "approved", not the deck full of vanity metrics.' },
              { icon: '☁️', title: 'Hands-on cloud delivery', desc: 'Two live deployments on Cloudflare\'s edge: hkepark.com (bilingual EN / 繁中, serverless prototype components) and chentian.aiden04c.workers.dev. I own scope, content, IA, DNS, deployment and monitoring. Enough engineering empathy to demo, debug and de-risk a customer call.' },
              { icon: '🌏', title: 'APAC-fluent, market-ready', desc: 'Native Mandarin, fluent English, working Cantonese. Personal and professional ground-truth across Singapore, Hong Kong, Mainland China and the UK. I can carry a customer conversation in three languages and read the room in each one.' },
            ].map(h => (
              <div class="highlight">
                <div class="highlight-icon">{h.icon}</div>
                <div class="highlight-content">
                  <h4>{h.title}</h4>
                  <p>{h.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section -->
  <section id="projects" class="projects">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Selected Work</span>
        <h2 class="section-title">Projects &amp; Engagements</h2>
        <p class="section-description">Two platforms I built and shipped — a government-pitch site and an international market-entry play — plus two account management case studies showing how I win, deliver, and grow client relationships.</p>
      </div>

      <div class="projects-grid">
        <!-- HKePark — featured -->
        <article class="project-card featured">
          <div class="project-header">
            <div class="project-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="10" rx="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                <circle cx="12" cy="16" r="1.5"/>
              </svg>
            </div>
            <div class="project-tags">
              <span class="tag">Cloudflare Workers</span>
              <span class="tag">i18n EN / 繁中</span>
              <span class="tag">Government Pitch</span>
              <span class="tag">Digital Marketing</span>
              <span class="tag">Google Ads</span>
            </div>
          </div>
          <h3 class="project-title">HKePark — Smart Curb Billing for Hong Kong</h3>
          <p class="project-description">
            HKePark is a usage-based curbside parking system that bills drivers by the minute via the existing HKeToll app — no coins, no tickets, no wardens. Hong Kong's parking supply grew 9% over a decade while vehicles rose 36%; the prototype is being pitched to the HKSAR Transport Department, backed by the Hong Kong Productivity Council and the Smart Traffic Fund. A joint NUS × HKUST initiative.
          </p>
          <div class="card-expand">
            <div class="card-expand-body">
              <p class="project-description">
                <strong>My role:</strong> co-authored the funding proposal aligning technical, commercial and public-sector stakeholders into a single go-to-market case; built cost models and supplier comparisons for proof-of-concept hardware across Mainland China and APAC; and shipped the bilingual marketing site on Cloudflare — the digital centrepiece of the government pitch, designed to build institutional trust and educate stakeholders on the system.
              </p>
              <p class="project-description">
                <strong>Growth strategy:</strong> the site is built to scale into a full public-awareness campaign — Google Search &amp; Display Ads targeting Hong Kong commuters, YouTube pre-rolls explaining the system, and retargeting flows to drive HKeToll app adoption once the pilot launches. The goal: turn a government-approval pitch asset into a demand-generation engine for public uptake.
              </p>
            </div>
            <button class="card-expand-toggle" aria-expanded="false">
              <span class="expand-label">Read more</span>
              <svg class="expand-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <div class="project-features">
            <div class="feature"><span class="feature-label">Live at</span><span class="feature-value"><a href="https://hkepark.com" target="_blank" rel="noopener">hkepark.com</a></span></div>
            <div class="feature"><span class="feature-label">My role</span><span class="feature-value">Proposal · Cost modelling · Cloudflare delivery · Growth strategy</span></div>
            <div class="feature"><span class="feature-label">Backers</span><span class="feature-value">HK Productivity Council · Smart Traffic Fund</span></div>
          </div>
          <div class="solution-flow">
            <div class="solution-flow-header">
              <span class="solution-flow-label">How HKePark works — end-to-end</span>
            </div>
            <div class="solution-steps">
              <div class="solution-step">
                <span class="step-num">1</span>
                <div class="step-content">
                  <span class="step-title">Vehicle arrives</span>
                  <span class="step-desc">Driver parks at a designated HKePark curb zone</span>
                </div>
              </div>
              <div class="solution-step-arrow">→</div>
              <div class="solution-step">
                <span class="step-num">2</span>
                <div class="step-content">
                  <span class="step-title">Auto-detection</span>
                  <span class="step-desc">RFID phased-array identifies vehicle; AI camera as failover</span>
                </div>
              </div>
              <div class="solution-step-arrow">→</div>
              <div class="solution-step">
                <span class="step-num">3</span>
                <div class="step-content">
                  <span class="step-title">Billing by the minute</span>
                  <span class="step-desc">No coins, no tickets, no wardens needed</span>
                </div>
              </div>
              <div class="solution-step-arrow">→</div>
              <div class="solution-step">
                <span class="step-num">4</span>
                <div class="step-content">
                  <span class="step-title">Tap to settle</span>
                  <span class="step-desc">HKeToll push notification · driver pays via existing app</span>
                </div>
              </div>
            </div>
            <div class="solution-flow-footer">
              <span class="solution-tag">Cloudflare Edge</span>
              <span class="solution-divider">·</span>
              <span class="solution-tag">Bilingual EN / 繁中</span>
              <span class="solution-divider">·</span>
              <span class="solution-tag">Investor &amp; govt demo site</span>
            </div>
          </div>
        </article>

        <!-- Chen Tian -->
        <article class="project-card">
          <div class="project-header">
            <div class="project-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="6.5" cy="17.5" r="2.5"/>
                <circle cx="17.5" cy="17.5" r="2.5"/>
                <path d="M3 17.5V13l2-5h10l4 4h2v5.5"/>
                <path d="M9 17.5h6"/>
              </svg>
            </div>
            <div class="project-tags">
              <span class="tag">Cloudflare Workers</span>
              <span class="tag">Cross-Border Growth</span>
              <span class="tag">Google Ads</span>
              <span class="tag">Multi-channel Strategy</span>
            </div>
          </div>
          <h3 class="project-title">Chen Tian Auto Parts — Cross-Border Market Expansion</h3>
          <p class="project-description">
            A Mainland China auto-parts supplier running entirely on domestic social platforms — WeChat Store, Douyin product posts, Xiaohongshu brand pages — with zero international web presence and no way for overseas buyers to validate the brand. I acted as advisor, solution architect, and delivery lead: scoped the requirement, designed the content strategy and site architecture, built and deployed on Cloudflare, and handed over an analytics-instrumented platform ready to grow.
          </p>
          <div class="card-expand">
            <div class="card-expand-body">
              <p class="project-description">
                <strong>Growth strategy:</strong> consolidate domestic reach via Baidu Search Ads and WeChat Official Account campaigns for brand authority within China; then expand into SEA and global markets via Google Search &amp; Shopping Ads targeting automotive distributors and B2B buyers in Singapore, Malaysia, and wider APAC. The international storefront becomes the conversion destination across all channels — a single credible URL the sales team can share with any buyer, anywhere.
              </p>
            </div>
            <button class="card-expand-toggle" aria-expanded="false">
              <span class="expand-label">Read more</span>
              <svg class="expand-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <div class="project-features">
            <div class="feature"><span class="feature-label">Live at</span><span class="feature-value"><a href="https://chentian.aiden04c.workers.dev" target="_blank" rel="noopener">chentian.aiden04c.workers.dev</a></span></div>
            <div class="feature"><span class="feature-label">My role</span><span class="feature-value">Advisor · Solution Design · Full-stack Delivery · Growth Strategy</span></div>
            <div class="feature"><span class="feature-label">Impact</span><span class="feature-value">First international storefront · domestic→global channel expansion · overseas pipeline enabled</span></div>
          </div>
        </article>

        <!-- Knight Frank — case study (commercial) -->
        <article class="project-card">
          <div class="project-header">
            <div class="project-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 21h18"/>
                <path d="M5 21V8l7-5 7 5v13"/>
                <path d="M9 21v-6h6v6"/>
              </svg>
            </div>
            <div class="project-tags">
              <span class="tag">Account Management</span>
              <span class="tag">Solution Advisory</span>
              <span class="tag">Proposal &amp; Pricing</span>
              <span class="tag">Singapore</span>
            </div>
          </div>
          <h3 class="project-title">Knight Frank — Account Management &amp; Strategic Delivery</h3>
          <p class="project-description">
            Acted as the client-facing account lead on workplace consulting and fit-out engagements across Singapore. Ran discovery sessions, translated site-usage data into right-sizing and adjacency recommendations, and built the commercial case that moved clients from brief to signature. Won 5 workplace consulting and fit-out projects (S$1–2M each, S$9M+ portfolio total) — each win driven by a tailored proposal that positioned cost/risk trade-offs and a master programme clients could defend to their own boards.
          </p>
          <div class="card-expand">
            <div class="card-expand-body">
              <p class="project-description">
                <strong>Post-award delivery:</strong> Oversaw cash flow and delivery schedule on two S$1–2M projects, coordinating 20+ change requests across clients, consultants and contractors. Drove 13–15% post-handover cost reduction through strategic value engineering: challenging scope assumptions, running competitive vendor re-tenders, and reconciling final accounts — savings that directly improved client ROI and strengthened the relationship for follow-on work.
              </p>
            </div>
            <button class="card-expand-toggle" aria-expanded="false">
              <span class="expand-label">Read more</span>
              <svg class="expand-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <div class="project-features">
            <div class="feature"><span class="feature-label">Deal outcome</span><span class="feature-value">5 wins · S$9M+ portfolio · avg S$1–2M per deal</span></div>
            <div class="feature"><span class="feature-label">Cost outcome</span><span class="feature-value">13–15% reduction via value engineering &amp; negotiation</span></div>
            <div class="feature"><span class="feature-label">AM approach</span><span class="feature-value">Discovery → Proposal → Negotiation → Delivery → Value optimisation</span></div>
          </div>
        </article>

        <!-- CBRE — case study (CX & analytics) -->
        <article class="project-card featured">
          <div class="project-header">
            <div class="project-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <path d="M3 9h18"/>
                <path d="M9 21V9"/>
                <path d="M13 14h5"/>
                <path d="M13 17h5"/>
              </svg>
            </div>
            <div class="project-tags">
              <span class="tag">Stakeholder Management</span>
              <span class="tag">Client-Ops Interface</span>
              <span class="tag">KPI &amp; Reporting</span>
              <span class="tag">Singapore</span>
            </div>
          </div>
          <h3 class="project-title">CBRE Asia Pacific — Client Interface &amp; Operational Visibility</h3>
          <p class="project-description">
            Residential property management at Reflections @ Keppel Bay, where I served as the day-to-day interface between the service-delivery teams and the client property owner — translating messy operational data into clear business terms the client could understand and act on. Introduced digital KPI and work-order dashboards that gave both internal teams and the client a single, real-time view of operational performance, replacing fragmented email updates with a shared source of truth.
          </p>
          <div class="card-expand">
            <div class="card-expand-body">
              <p class="project-description">
                <strong>Pipeline & outcomes:</strong> Built a resident request-intake pipeline that structured inbound feedback into actionable work orders — improving response consistency and resident satisfaction scores. This is the case study I reach for when a hiring manager asks: <em>"How do you bridge the gap between a technical team and a non-technical client?"</em>
              </p>
            </div>
            <button class="card-expand-toggle" aria-expanded="false">
              <span class="expand-label">Read more</span>
              <svg class="expand-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M2 5l5 5 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
          <div class="project-features">
            <div class="feature"><span class="feature-label">AM parallel</span><span class="feature-value">Client owner ↔ Ops team — translating needs in both directions</span></div>
            <div class="feature"><span class="feature-label">Skills shown</span><span class="feature-value">Client reporting · Stakeholder alignment · Data → decisions</span></div>
            <div class="feature"><span class="feature-label">Outcome</span><span class="feature-value">Lifted response consistency, resident satisfaction &amp; client visibility</span></div>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section id="skills" class="skills">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Capabilities</span>
        <h2 class="section-title">Skills &amp; Toolkit</h2>
        <p class="section-description">A pragmatic toolkit for client-facing technical roles — strong on commercial fundamentals, with enough cloud and data depth to ship.</p>
      </div>
      <div class="skills-grid">
        {[
          {
            icon: '☁️',
            title: 'Cloud &amp; Web Delivery',
            items: ['Cloudflare Workers', 'Cloudflare Pages', 'KV', 'R2', 'DNS', 'Load Balancing', 'HTML', 'CSS', 'Git / GitHub']
          },
          {
            icon: '📊',
            title: 'Data, Measurement &amp; Tools',
            items: ['SQL', 'Google Analytics 4', 'Google Ads (Measurement Certified®)', 'Conversion tracking', 'Excel / Google Sheets', 'Microsoft Project']
          },
          {
            icon: '🤝',
            title: 'Client &amp; Account Skills',
            items: ['Multi-stakeholder coordination', 'Proposal writing', 'Pricing &amp; cost estimation', 'RAID logs', 'Change-request management', 'Vendor negotiation', 'Senior-stakeholder updates']
          },
          {
            icon: '🌏',
            title: 'Languages &amp; Markets',
            items: ['English (fluent)', 'Mandarin (native)', 'Cantonese (working)', 'Singapore', 'Hong Kong', 'Mainland China', 'United Kingdom']
          },
          {
            icon: '🎓',
            title: 'Education &amp; Certifications',
            items: ['MSc Building Performance &amp; Sustainability — NUS', 'BEng (Hons) Civil Engineering — Loughborough', 'Google Ads Measurement Certified®']
          },
          {
            icon: '🧭',
            title: 'How I Work',
            items: ['Client-first', 'Decision-ready briefs', 'Ship → measure → iterate', 'Bilingual storytelling', 'Comfort with ambiguity']
          },
        ].map(cat => (
          <div class="skill-category">
            <h3 class="skill-category-title"><span class="skill-icon">{cat.icon}</span> <span set:html={cat.title}></span></h3>
            <div class="skill-items">
              {cat.items.map(item => <div class="skill-item" set:html={item}></div>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Contact Section -->
  <section id="contact" class="contact">
    <div class="container">
