                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <div class="project-tags">
              <span class="tag">GitLab CI</span><span class="tag">YAML</span><span class="tag">DevOps</span>
            </div>
          </div>
          <h3 class="project-title">CI/CD Template Library</h3>
          <p class="project-description">
            A comprehensive library of reusable GitLab CI templates for accelerating
            project setup. Includes templates for Node.js, Go, security scanning,
            Kaniko builds, ArgoCD deployments, and more.
          </p>
          <div class="project-features">
            <div class="feature"><span class="feature-label">Templates</span><span class="feature-value">20+</span></div>
            <div class="feature"><span class="feature-label">Categories</span><span class="feature-value">Build, Test, Deploy, Security</span></div>
          </div>
          <div class="code-preview">
            <div class="code-header"><span class="code-file">argocd-deploy.yml</span></div>
            <pre class="code-block"><code><span class="code-key">.argocd-dev-deploy</span>:
  <span class="code-key">stage</span>: deploy
  <span class="code-key">variables</span>:
    <span class="code-key">ARGOCD_SERVER</span>: <span class="code-var">$DEV_ARGOCD_SERVER</span>
    <span class="code-key">ARGOCD_SYNC_TIMEOUT</span>: <span class="code-num">600</span>
  <span class="code-key">script</span>:
    - argocd app sync <span class="code-var">$APP_NAME</span> --grpc-web
    - argocd app wait <span class="code-var">$APP_NAME</span> --timeout <span class="code-var">$TIMEOUT</span></code></pre>
          </div>
        </article>

        <article class="project-card">
          <div class="project-header">
            <div class="project-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <div class="project-tags"><span class="tag">Kubernetes</span><span class="tag">Alibaba Cloud</span></div>
          </div>
          <h3 class="project-title">Alibaba Cloud Kubernetes</h3>
          <p class="project-description">Production Kubernetes cluster configurations for Alibaba Cloud (Aliyun). Includes ArgoCD applications, Helm deployments, and cluster management scripts.</p>
          <div class="project-features">
            <div class="feature"><span class="feature-label">Components</span><span class="feature-value">ArgoCD, Helm, Deploy Scripts</span></div>
          </div>
        </article>

        <article class="project-card">
          <div class="project-header">
            <div class="project-icon">
